<!DOCTYPE html>
<html>
<head>
    <title>Edit User</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900 flex justify-center items-center min-h-screen">

<form action="/update/<%= user._id %>" method="POST"
class="bg-zinc-800 p-8 rounded-xl w-96 space-y-5">

    <h1 class="text-3xl text-white font-bold">
        Edit User
    </h1>

    <input
        type="text"
        name="name"
        value="<%= user.name %>"
        class="w-full p-3 rounded bg-zinc-700 text-white">

    <input
        type="text"
        name="username"
        value="<%= user.username %>"
        class="w-full p-3 rounded bg-zinc-700 text-white">

    <input
        type="email"
        name="email"
        value="<%= user.email %>"
        class="w-full p-3 rounded bg-zinc-700 text-white">

    <button
        class="bg-blue-600 w-full p-3 rounded text-white">
        Update User
    </button>

</form>

</body>
</html>