<!DOCTYPE html>
<html>
<head>
    <title>Create User</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-900 flex justify-center items-center min-h-screen">

<form action="/create" method="POST"
class="bg-zinc-800 p-8 rounded-xl w-96 space-y-5">

    <h1 class="text-white text-3xl font-bold">
        Create User
    </h1>

    <input
        type="text"
        name="name"
        placeholder="Name"
        class="w-full p-3 rounded bg-zinc-700 text-white">

    <input
        type="text"
        name="username"
        placeholder="Username"
        class="w-full p-3 rounded bg-zinc-700 text-white">

    <input
        type="email"
        name="email"
        placeholder="Email"
        class="w-full p-3 rounded bg-zinc-700 text-white">
    <input
        type="text"
        name="image"
        placeholder="Image url"
        class="w-full p-3 rounded bg-zinc-700 text-white">
    <button
        class="bg-blue-600 w-full p-3 rounded text-white">
        Create User
    </button>

</form>

</body>
</html>